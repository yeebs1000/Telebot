# Which AI provider powers chat, intent routing, and (where supported)
# embeddings. One of: gemini, openai, claude
AI_PROVIDER=gemini

# Optional — override the default model for your chosen provider.
# Defaults: gemini -> gemini-3.1-flash-lite, openai -> gpt-4o-mini,
# claude -> claude-sonnet-4-6
AI_MODEL=

# Telegram bot token from @BotFather — required
TELEGRAM_BOT_TOKEN=

# --- AI provider API keys — only fill in the one matching AI_PROVIDER ---

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
# Note: Claude has no embeddings API, so semantic memory search is
# automatically disabled while AI_PROVIDER=claude.
ANTHROPIC_API_KEY=

# Supabase project URL and service/anon key — required for chat logging,
# semantic memory, and live polls (https://supabase.com)
SUPABASE_URL=
SUPABASE_KEY=

# Tavily API key — optional, enables live web search (https://tavily.com)
TAVILY_API_KEY=

# Alpha Vantage API key — optional, enables stock/forex/commodity quotes
# (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=
